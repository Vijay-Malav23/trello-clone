# Copy to .env and adjust values.

# MongoDB — pick ONE style of URI:

# Local (MongoDB Community / Docker on your machine)
MONGODB_URI=mongodb://127.0.0.1:27017/trello_clone

# Atlas (cloud): Dashboard → Connect → Drivers → copy connection string.
# Replace <password> and set a database name at the end, e.g. ...mongodb.net/trello_clone?retryWrites=true&w=majority
# MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster0.xxxxx.mongodb.net/trello_clone?retryWrites=true&w=majority

# Auth (use a long random string in production)
JWT_SECRET=change_me_to_something_long_and_random

# API port (optional; client dev proxy expects 5000)
PORT=5000
